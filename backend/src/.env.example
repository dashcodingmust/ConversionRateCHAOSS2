# Copy this file to .env and fill in your GitHub tokens.
# A token is optional but strongly recommended to avoid rate limiting (60 req/hr → 5000 req/hr).

# Option A — single token (shows as "Default" in the UI)
GITHUB_TOKEN=your_github_personal_access_token_here

# Option B — multiple named tokens (overrides GITHUB_TOKEN if set)
# Format: JSON object mapping display name → token
# GITHUB_TOKENS_JSON={"Alice": "ghp_xxx", "Bob": "ghp_yyy", "CI Bot": "ghp_zzz"}

# Cache TTLs (seconds)
ANALYZE_CACHE_TTL=3600
REPOS_CACHE_TTL=300
